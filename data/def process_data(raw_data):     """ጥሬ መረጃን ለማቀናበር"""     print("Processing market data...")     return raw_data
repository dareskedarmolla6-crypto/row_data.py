import time


class RawDataStore:
    """
    Stores raw market data before processing by brain/strategy.
    Used for:
    - backtesting
    - signal validation
    - debugging
    """

    def __init__(self):
        self.buffer = []

    # =========================
    # ADD RAW MARKET DATA
    # =========================
    def add(self, symbol: str, data: dict):
        self.buffer.append({
            "symbol": symbol,
            "data": data,
            "ts": int(time.time())
        })

    # =========================
    # GET ALL RAW DATA
    # =========================
    def get_all(self):
        return self.buffer

    # =========================
    # GET LAST N RECORDS
    # =========================
    def get_last(self, n=50):
        return self.buffer[-n:]

    # =========================
    # CLEAR BUFFER
    # =========================
    def clear(self):
        self.buffer = []

    # =========================
    # FILTER BY SYMBOL
    # =========================
    def get_by_symbol(self, symbol: str):
        return [
            item for item in self.buffer
            if item["symbol"] == symbol
        ]
